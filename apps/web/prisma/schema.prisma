// admin_data_project — Prisma schema
// See plan: ~/.claude/plans/trabajo-en-m-ltiples-proyectos-*.md

generator client {
  provider      = "prisma-client-js"
  // "native" cubre tu dev local (Windows / macOS).
  // "linux-musl-openssl-3.0.x" cubre el runtime de Docker (node:22-alpine 3.20+).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// Lifecycle state of a project. Only OWNER/ADMIN can change it.
enum ProjectStatus {
  ACTIVE      // en marcha
  PAUSED      // pausado temporalmente
  INACTIVE    // desactivado
  COMPLETED   // completado / cerrado
}

enum StateCategory {
  OPEN
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CredType {
  EMAIL_LOGIN
  PASSWORD
  API_KEY
  SSH_KEY
  NOTE
  CERT
}

enum TaskKind {
  TASK
  STORY
  EPIC
  BUG
  SPIKE
}

enum LlmProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
  MOONSHOT
}

enum StoryDraftStatus {
  GENERATING
  READY
  ERRORED
  PUBLISHED
}

enum TaskActivityType {
  CREATED
  STATE_CHANGED
  ASSIGNED
  UNASSIGNED
  PRIORITY_CHANGED
  TITLE_CHANGED
  DESCRIPTION_CHANGED
  DUE_DATE_CHANGED
  COMMENTED
  SUBTASK_ADDED
  DEPENDENCY_ADDED
  MEMORY_CITED
  MEMORY_CAPTURED
}

enum BrainScope {
  LOCAL
  PROJECT
}

enum MemoryType {
  DECISION
  GOTCHA
  PATTERN
  ANTIPATTERN
  RUNBOOK
  GLOSSARY
  NOTE
}

enum MemoryStatus {
  ACTIVE
  DEPRECATED
  SUPERSEDED
}

enum DependencyKind {
  BLOCKS
  BLOCKED_BY
  RELATES_TO
}

// ============================================================
// Identity & access
// ============================================================

model User {
  id                  String  @id @default(cuid())
  email               String  @unique
  name                String
  passwordHash        String  // argon2id, solo para login (no se reusa como KEK)
  publicKey           Bytes   // X25519 (32 bytes)
  encryptedPrivateKey Bytes   // sk_user envuelto con KEK derivado de passphrase
  encryptedPrivKeyNonce Bytes // nonce del XSalsa20-Poly1305
  kdfSalt             Bytes   // salt para argon2id (derivación del KEK)
  recoveryHash        String? // SHA-256 (proof) del recovery code normalizado
  encryptedPrivKeyRecovery Bytes? // sk_user envuelto con KEK derivado del recovery code
  recoveryPrivKeyNonce     Bytes? // nonce del XSalsa20-Poly1305 (copia recovery)
  recoveryKdfSalt          Bytes? // salt argon2id para la copia recovery
  totpSecretEncrypted Bytes?  // TOTP secret envuelto con KEK
  totpNonce           Bytes?
  isMasterUser        Boolean @default(false)
  githubLogin         String? // handle de GitHub (para verificar acceso a repos)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships     ProjectMember[]
  ownedProjects   Project[]          @relation("ProjectOwner")
  apiTokens       ApiToken[]
  auditEntries    AuditLog[]
  assignedTasks   Task[]             @relation("TaskAssignee")
  reportedTasks   Task[]             @relation("TaskReporter")
  taskComments    TaskComment[]
  taskActivities  TaskActivity[]
  createdCreds    Credential[]       @relation("CredentialCreator")
  grantedCredAccs CredentialAccess[] @relation("CredentialAccessGrantor")
  credAccesses    CredentialAccess[] @relation("CredentialAccessUser")
  aiInteractions  AiInteraction[]
  authoredMemories BrainMemory[]    @relation("MemoryAuthor")
  localMemories    BrainMemory[]    @relation("MemoryLocalOwner")
  memoryCitations  MemoryCitation[] @relation("MemoryCitedBy")
  brainSyncStates  BrainSyncState[]
  llmCredentials   LlmCredential[]
  storyDrafts      StoryDraft[]
  uploadedFiles    ProjectFile[]    @relation("FileUploader")
  authoredPlans    ProjectPlan[]    @relation("PlanAuthor")
  invitesSent      Invitation[]     @relation("InvitedBy")
  passwordResets   PasswordResetToken[]
  agentIdentities  Agent[]

  @@index([email])
}

// Invite-only onboarding: a master user invites an email; the recipient
// registers by presenting the token (only its sha256 is stored). Public
// self-signup is disabled — a valid, unexpired, unaccepted invite is required.
model Invitation {
  id          String    @id @default(cuid())
  email       String
  tokenHash   String    @unique // sha256 hex of the plaintext token
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  // When set, accepting this invite (on signup) also joins the user to the
  // project with the given role — lets a project OWNER/ADMIN invite someone who
  // doesn't have an account yet.
  projectId   String?
  projectRole MemberRole?
  // Optional seniority captured at invite time (for AI time estimation). Carried
  // onto the ProjectMember when the invitee signs up and auto-joins the project.
  seniority   Seniority?

  invitedBy   User @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
}

// Login-password reset (separate from the E2E vault: this only restores server
// authentication; the vault stays protected by its own passphrase / recovery
// code). The recipient presents the token (only its sha256 is stored), one use.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // sha256 hex of the plaintext token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Auth.js v5 session storage (when using DB strategy).
// Kept minimal — only what Auth.js needs.
model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime

  @@index([userId])
}

// ============================================================
// Projects
// ============================================================

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  ownerId     String

  // Repositorio asociado (lectura desde el filesystem del server)
  repoPath           String?
  repoUrl            String?
  repoDefaultBranch  String?  @default("main")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User               @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  workflows   Workflow[]
  tasks       Task[]
  credentials Credential[]
  taskCounter ProjectTaskCounter?
  brainMemories BrainMemory[]
  brainSyncStates BrainSyncState[]
  llmCredentials LlmCredential[]
  storyDrafts    StoryDraft[]
  files          ProjectFile[]
  sprints        Sprint[]
  plans          ProjectPlan[]
  contextSummaries ContextSummary[]
  repos          ProjectRepo[]
  analysis       CodeAnalysis?
  deployTarget   DeployTarget?
  agents         Agent[]
  teamMessages   TeamChatMessage[]

  @@index([ownerId])
}

// Lifecycle of a project's code knowledge-graph analysis (graphify over its repos).
enum AnalysisStatus {
  PENDING    // creada, aún no corre
  ANALYZING  // graphify-svc clonando/analizando
  READY      // grafo listo
  FAILED     // falló (ver error)
}

// Grafo de conocimiento del CÓDIGO real del proyecto, producido por graphify-svc
// (clona los repos y corre `graphify extract`). Uno por proyecto; el grafo combina
// todos sus repos. Alimenta la planeación brownfield (lib/ai/planner.ts) y siembra
// el cerebro. Ver apps/graphify-svc y lib/analysis/.
model CodeAnalysis {
  id        String         @id @default(cuid())
  projectId String         @unique
  status    AnalysisStatus @default(PENDING)
  graph     Json?          // node-link { nodes, edges/links, communities en nodos }
  summary   String?        @db.Text // brief narrativo (describeCodeGraph)
  godNodes  Json?          // top nodos por grado (conceptos centrales)
  stats     Json?          // { nodes, edges, communities, tokensIn, tokensOut, costUsd }
  backend   String?        // motor de extracción usado (deepseek|claude|…)
  repos     Json?          // repos analizados [{ name, githubFullName }]
  error     String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Un proyecto puede tener varios repos / aplicativos. Fuente de verdad para la
// sección de Repositorios del plan (crear en GitHub / vincular / verificar acceso)
// y para que el plan de implementación lea el repo correcto por HU.
model ProjectRepo {
  id             String   @id @default(cuid())
  projectId      String
  name           String                 // identificador lógico dentro del proyecto
  kind           String   @default("other") // backend|frontend|infra|mobile|shared|other
  url            String?                // https://github.com/owner/repo
  githubFullName String?                // owner/repo
  defaultBranch  String?  @default("main")
  private        Boolean  @default(true)
  repoPath       String?                // ruta absoluta en el server para lectura de archivos
  access         Json?                  // [{ userId, name, login, hasAccess, permission }]
  accessCheckedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]

  @@unique([projectId, name])
  @@index([projectId])
}

// Binding de un proyecto Axon a fusion-infra (el PaaS): el proyecto/entorno
// fusion-infra auto-creado donde se despliegan sus repos. Uno por proyecto. Ver
// lib/deploy/fusion-client.ts y lib/actions/deploy.ts.
model DeployTarget {
  id              String @id @default(cuid())
  projectId       String @unique
  fusionTeamId    String
  fusionProjectId String // proyecto fusion-infra auto-creado (POST /projects)
  environmentId   String // su entorno "production" por defecto (o elegido)
  serverId        String // host fusion-infra elegido
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]
}

// Un despliegue concreto = una application en fusion-infra (un repo desplegado o
// una app/DB importada). Espeja el estado del control-plane (status/hostname) para
// que Axon lo muestre sin re-consultar en cada render.
model Deployment {
  id               String  @id @default(cuid())
  deployTargetId   String
  projectRepoId    String? // repo Axon origen (null si importada/standalone)
  fusionAppId      String  // id de la application en fusion-infra
  kind             String  @default("APP") // APP|DATABASE
  name             String
  hostname         String? // URL pública viva (auto-domain de fusion-infra)
  buildPack        String  @default("DOCKERFILE") // DOCKERFILE|DOCKER_IMAGE|STATIC
  exposedPort      Int?
  status           String  @default("PENDING") // mirror de latestDeployment.status
  lastDeploymentId String? // deploymentId fusion para polling de estado
  error            String? @db.Text
  imported         Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  deployTarget DeployTarget @relation(fields: [deployTargetId], references: [id], onDelete: Cascade)
  projectRepo  ProjectRepo? @relation(fields: [projectRepoId], references: [id], onDelete: SetNull)

  @@unique([deployTargetId, fusionAppId])
  @@index([deployTargetId])
  @@index([projectRepoId])
}

// Categoría de archivo derivada del mime-type al subir; usada para agrupar
// el almacén de archivos del proyecto por tipo.
enum FileCategory {
  IMAGE
  DOCUMENT
  SPREADSHEET
  PRESENTATION
  PDF
  ARCHIVE
  AUDIO
  VIDEO
  CODE
  OTHER
}

// Almacén de archivos por proyecto. Accesible a cualquier miembro. Los bytes
// viven en `data` (bytea) — NUNCA seleccionar `data` al listar; sólo la ruta de
// descarga lo lee. Organizado por `category` (tipo) y `createdAt` (fecha).
model ProjectFile {
  id           String       @id @default(cuid())
  projectId    String
  name         String
  mimeType     String
  size         Int
  category     FileCategory @default(OTHER)
  // Object key in MinIO/S3 (bytes live there, not in Postgres):
  //   projects/<slug>/<category>/<YYYY-MM>/<fileId>-<name>
  storageKey   String
  uploadedById String
  // When true, this file is USED as context in the AI planning + chat (the user's
  // decision). For documents this requires a generated context artifact (below);
  // images are fed as native vision blocks.
  isContext     Boolean     @default(false)
  // Two-step "convert to context": extractedText is the raw 0-token extraction
  // cache (intermediate); contextMarkdown is the AI-cleaned .md artifact that is
  // downloadable and grounds planning. contextStatus tracks the generation.
  extractedText   String?   @db.Text
  contextStatus   String    @default("NONE") // NONE | GENERATING | READY | FAILED
  contextMarkdown String?   @db.Text
  contextError    String?   @db.Text
  createdAt    DateTime     @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("FileUploader", fields: [uploadedById], references: [id])

  @@index([projectId, createdAt])
  @@index([projectId, category])
  @@index([projectId, isContext])
}

// Tracks the next task number per project (for sequential PROJ-N numbering).
model ProjectTaskCounter {
  projectId String @id
  next      Int    @default(1)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum Seniority {
  JUNIOR
  SEMI_SENIOR
  SENIOR
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String
  userId    String
  role      MemberRole
  seniority Seniority? // perfil de seniority en el proyecto (para estimar tiempos)
  joinedAt  DateTime   @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

// ============================================================
// Workflows & tasks
// ============================================================

model Workflow {
  id        String @id @default(cuid())
  projectId String
  name      String
  isDefault Boolean @default(false)

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  states  WorkflowState[]

  @@unique([projectId, name])
}

model WorkflowState {
  id         String        @id @default(cuid())
  workflowId String
  name       String
  color      String
  order      Int
  category   StateCategory

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tasks    Task[]

  @@unique([workflowId, name])
  @@index([workflowId, order])
}

model Task {
  id           String   @id @default(cuid())
  projectId    String
  parentTaskId String?
  stateId      String
  taskNumber   Int      // secuencial por proyecto (PROJ-N)
  title        String
  description  String?  @db.Text // markdown
  priority     Priority @default(MEDIUM)
  assigneeId   String?
  reporterId   String
  dueDate      DateTime?
  positionInState Int   @default(0) // para preservar orden manual dentro de una columna
  kind         TaskKind @default(TASK)
  // Planning fields (set by the AI planner; optional so manual tasks are unaffected).
  acceptanceCriteria String?  @db.Text
  estimate           String?  // rango representativo "junior–senior" (asistido por IA)
  estimateBySeniority Json?   // { junior, semiSenior, senior } esfuerzo asistido por IA
  category           String?  // infra/backend/frontend/design/qa/devops/docs/other (roadmap lanes)
  recommendedRoles   String[] // perfiles sugeridos
  sprintId           String?
  // QA workflow. qaHandoff = lo que el dev entrega al cerrar la HU (criterios ✓/✗,
  // pruebas sugeridas, tareas ejecutadas, notas); qaTests = pruebas propias del QA
  // (generadas por IA / editadas). Ambos opcionales y retro-compatibles.
  qaHandoff          Json?
  qaTests            Json?
  // Plan de implementación (markdown, generado por IA): contexto técnico de la HU
  // que el agente Dev genera al tomarla y usa para implementar mejor. Visible en el
  // detalle de la HU. Opcional y retro-compatible.
  implPlan           String?  @db.Text
  implPlanAt         DateTime?
  // Spec de diseño (markdown, generado por el agente Diseño/Aria): notas de UI/UX
  // (layout, componentes, estados, a11y, responsive) + referencia al mockup de
  // concepto (imagen gpt-image-1 en el store). Para HUs de UI; el Dev implementa
  // contra esto. Opcional y retro-compatible.
  designSpec         String?  @db.Text
  designSpecAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Task?            @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks    Task[]           @relation("Subtasks")
  sprint      Sprint?          @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  state       WorkflowState    @relation(fields: [stateId], references: [id])
  assignee    User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter    User             @relation("TaskReporter", fields: [reporterId], references: [id])
  comments    TaskComment[]
  activity    TaskActivity[]
  dependsOn   TaskDependency[] @relation("DependsOnSource")
  dependents  TaskDependency[] @relation("DependsOnTarget")
  sourceForMemories BrainMemory[]    @relation("MemorySourceTask")
  agentRuns   AgentRun[]       @relation("AgentRunStory")
  teamMessages TeamChatMessage[] @relation("TeamChatStory")
  memoryCitations   MemoryCitation[] @relation("MemoryCitedInTask")
  publishedFromDraft StoryDraft?     @relation("PublishedFrom")

  @@unique([projectId, taskNumber])
  @@index([projectId, stateId])
  @@index([assigneeId])
  @@index([parentTaskId])
  @@index([sprintId])
}

// A sprint groups planned tasks; the roadmap lays sprints out as columns.
model Sprint {
  id        String   @id @default(cuid())
  projectId String
  name      String
  goal      String?  @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId, order])
}

enum PlanStatus {
  CHATTING
  GENERATING
  READY
  PUBLISHED
  FAILED
}

// AI-assisted planning session for a project: an interactive chat whose context
// drives Opus to generate sprints + tasks. Mirrors StoryDraft's lifecycle.
model ProjectPlan {
  id             String     @id @default(cuid())
  projectId      String
  createdById    String
  status         PlanStatus @default(CHATTING)
  messages       Json       @default("[]") // [{ role: 'assistant'|'user', content }]
  generated      Json?      // { sprints:[{name,goal,tasks:[...]}] }
  suggestedRepos Json?      // [{ name, kind, stack, reason }]
  improvedIdea   String?    @db.Text
  error          String?
  contextGraph   String?    // which graph grounds this plan: 'CODE_GRAPH' | 'NONE' | null (auto)
  // Per-user chat bubble colors, shared across the project (one plan per project):
  // { [userId]: "#rrggbb" }. Anyone can recolor anyone; synced live over SSE.
  chatColors     Json?
  // Live generation progress so the UI can show phase/elapsed and detect orphans
  // (set while status=GENERATING): { phase, startedAt }. heartbeatAt is bumped as
  // generation advances; a stale heartbeat with status=GENERATING ⇒ orphaned run.
  stats          Json?
  heartbeatAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User    @relation("PlanAuthor", fields: [createdById], references: [id])
  attachments PlanAttachment[]

  @@index([projectId, createdAt])
}

enum AttachmentKind {
  IMAGE
  DOCUMENT
  LINK
}

// Context the user attaches to a plan (images/docs in MinIO, or fetched web links).
// Images feed the generator as native image blocks; docs/links as extracted text.
model PlanAttachment {
  id            String         @id @default(cuid())
  planId        String
  kind          AttachmentKind
  name          String
  mimeType      String?
  size          Int?
  storageKey    String?        // MinIO key for IMAGE/DOCUMENT
  url           String?        // for LINK
  extractedText String?        @db.Text // DOCUMENT + LINK
  createdAt     DateTime       @default(now())

  plan ProjectPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId])
}

model TaskActivity {
  id        String           @id @default(cuid())
  taskId    String
  actorId   String
  type      TaskActivityType
  payload   Json?
  createdAt DateTime         @default(now())

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation(fields: [actorId], references: [id])

  @@index([taskId, createdAt])
}

model TaskDependency {
  id           String         @id @default(cuid())
  sourceTaskId String
  targetTaskId String
  kind         DependencyKind
  createdAt    DateTime       @default(now())

  source Task @relation("DependsOnSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  target Task @relation("DependsOnTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId, kind])
}

// ============================================================
// Vault E2E (zero-knowledge)
// ============================================================

model Credential {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  type           CredType
  ciphertext     Bytes    // secreto encriptado con DEK (XSalsa20-Poly1305)
  nonce          Bytes
  metadataPublic Json?    // metadata no sensible (username, URL) opt-in
  createdById    String
  rotatedAt      DateTime?
  // Se marca true al revocar acceso a un miembro: el DEK puede haber quedado
  // cacheado por el revocado, así que la credencial debe rotarse (re-cifrarse).
  needsRotation  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User               @relation("CredentialCreator", fields: [createdById], references: [id])
  access    CredentialAccess[]

  @@index([projectId])
}

model CredentialAccess {
  id           String   @id @default(cuid())
  credentialId String
  userId       String
  wrappedDek   Bytes    // DEK envuelto con pk_user (sealed box)
  grantedAt    DateTime @default(now())
  grantedById  String

  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  user       User       @relation("CredentialAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy  User       @relation("CredentialAccessGrantor", fields: [grantedById], references: [id])

  @@unique([credentialId, userId])
  @@index([userId])
}

// ============================================================
// API tokens (para MCP server y otros clientes)
// ============================================================

model ApiToken {
  id            String    @id @default(cuid())
  userId        String
  name          String
  tokenHash     String    @unique // sha256 hex del token plano
  prefix        String    // primeros 8 chars del token para mostrar al user
  scopes        String[]
  projectSlugs  String[]  // si está vacío, aplica a todos los proyectos del user
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent?

  @@index([userId])
  @@index([tokenHash])
}

// ============================================================
// Agentic platform (Fase 1): identidad y bitácora de agentes
// ============================================================

enum AgentRole {
  SM
  DEV
  QA
  PO
  DESIGN
  REVIEWER
}

enum AgentRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  BUDGET_EXCEEDED
  CANCELLED
}

// Un agente ES un usuario-miembro del proyecto y opera con su propio ApiToken:
// la auditoría y el guardarraíl anti auto-aprobación se aplican por identidad
// de token (plataforma), no por prompt.
model Agent {
  id            String   @id @default(cuid())
  projectId     String
  role          AgentRole
  userId        String
  apiTokenId    String?  @unique
  displayName   String?  // nombre propio del agente en el equipo (ej. "Nova")
  llmModel      String   // p.ej. "qwen3-coder-next" | "claude-sonnet-4-6"
  credentialRef String?  // 'server' | id de LlmCredential | null (Qwen vía env del worker)
  tokenBudget   Int      @default(200000) // presupuesto de tokens por corrida (corte duro)
  enabled       Boolean  @default(false)  // opt-in por proyecto: nace apagado
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiToken ApiToken? @relation(fields: [apiTokenId], references: [id], onDelete: SetNull)
  runs     AgentRun[]

  @@unique([projectId, role])
  @@index([userId])
}

// Chat del equipo: el "standup" permanente del proyecto. Cada agente narra su
// turno (tomó una HU, terminó, entrega al siguiente) y los humanos leen e
// intervienen en el mismo hilo. En vivo por Redis (canal team:{projectId}).
enum TeamMessageKind {
  CHAT    // conversación libre (humanos o agentes)
  STATUS  // avance/estado de un agente ("tomé la HU", "corrida FAILED")
  HANDOFF // entrega de turno ("PR listo → te toca QA")
}

model TeamChatMessage {
  id         String          @id @default(cuid())
  projectId  String
  authorId   String          // User (humano o cuenta de servicio del agente)
  agentRole  AgentRole?      // null = humano
  authorName String          // snapshot del nombre mostrado al momento de escribir
  kind       TeamMessageKind @default(CHAT)
  body       String
  storyId    String?         // HU relacionada (opcional)
  createdAt  DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  story   Task?   @relation("TeamChatStory", fields: [storyId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
}

// Bitácora de corridas: una fila por reacción de un agente a un evento.
// Persiste tokens/costo para atribución por rol y para el corte de presupuesto.
model AgentRun {
  id               String         @id @default(cuid())
  agentId          String
  storyId          String?        // Task.id que originó la corrida (null = housekeeping)
  status           AgentRunStatus @default(RUNNING)
  startedAt        DateTime       @default(now())
  finishedAt       DateTime?
  promptTokens     Int            @default(0)
  completionTokens Int            @default(0)
  costUsd          Decimal        @default(0) @db.Decimal(10, 6)
  error            String?
  payload          Json?          // evento disparador / resumen de la corrida

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  story Task? @relation("AgentRunStory", fields: [storyId], references: [id], onDelete: SetNull)

  @@index([agentId, startedAt])
  @@index([storyId])
}

// ============================================================
// Observability
// ============================================================

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  action       String   // p.ej. "credential.read", "task.update"
  resourceType String
  resourceId   String
  projectId    String?
  ip           String?
  userAgent    String?
  payload      Json?
  createdAt    DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([projectId, createdAt])
  @@index([resourceType, resourceId])
}

model AiInteraction {
  id              String   @id @default(cuid())
  userId          String
  projectId       String?
  taskId          String?
  model           String
  purpose         String
  inputTokens     Int
  outputTokens    Int
  cacheReadTokens Int      @default(0)
  estimatedCostUsd Decimal @db.Decimal(10, 6)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

// ============================================================
// Brain system
// ============================================================
// Each project has a shared "main brain" (scope=PROJECT) and a private "local
// brain" per dev (scope=LOCAL, ownerUserId=devId). On task close the AI
// extracts memories into the dev's local brain; publishing promotes them to
// PROJECT. See plan section "Sistema de cerebros por proyecto".

model BrainMemory {
  id             String       @id @default(cuid())
  projectId      String
  scope          BrainScope
  ownerUserId    String?      // required if scope=LOCAL
  authorId       String       // original creator
  type           MemoryType
  title          String
  body           String       @db.Text  // markdown
  tags           String[]
  sourceTaskId   String?
  status         MemoryStatus @default(ACTIVE)
  supersededById String?
  lastCitedAt    DateTime?
  citationCount  Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Postgres `search_vector tsvector` mantenido por un trigger declarado
  // en la migración brain_system. Lo declaramos aquí como Unsupported
  // para que Prisma no intente dropearlo en migraciones futuras.
  search_vector  Unsupported("tsvector")?

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author         User          @relation("MemoryAuthor", fields: [authorId], references: [id])
  ownerUser      User?         @relation("MemoryLocalOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceTask     Task?         @relation("MemorySourceTask", fields: [sourceTaskId], references: [id], onDelete: SetNull)
  supersededBy   BrainMemory?  @relation("Supersedure", fields: [supersededById], references: [id])
  supersedes     BrainMemory[] @relation("Supersedure")
  citations      MemoryCitation[]

  @@index([projectId, scope, status])
  @@index([ownerUserId, scope])
  @@index([sourceTaskId])
}

model MemoryCitation {
  id            String   @id @default(cuid())
  memoryId      String
  citedInTaskId String
  citedByUserId String
  context       String?
  createdAt     DateTime @default(now())

  memory      BrainMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  citedInTask Task        @relation("MemoryCitedInTask", fields: [citedInTaskId], references: [id], onDelete: Cascade)
  citedByUser User        @relation("MemoryCitedBy", fields: [citedByUserId], references: [id])

  @@index([memoryId, createdAt])
  @@index([citedInTaskId])
}

// Tracks per (user, project) the last time the user pulled, so pulls can be
// incremental rather than dumping the whole project brain every time.
model BrainSyncState {
  id           String    @id @default(cuid())
  userId       String
  projectId    String
  lastPulledAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// ============================================================
// HU generator · LLM credentials + drafts
// ============================================================
// Credenciales LLM por usuario (opcionalmente scoped a un proyecto).
// La key se sella server-side con AUTH_TOTP_KEY (XSalsa20-Poly1305) —
// el server puede descifrarla cuando invoca el LLM. Trade-off narrow
// zero-knowledge para que las llamadas a OpenAI/Gemini/etc funcionen
// desde server actions.

model LlmCredential {
  id            String       @id @default(cuid())
  userId        String
  projectId     String?
  provider      LlmProvider
  label         String
  encryptedKey  Bytes
  nonce         Bytes
  keyPrefix     String       // primeros 8 chars del key plano, solo para display
  modelDefault  String?      // modelo preferido al usar esta credencial
  lastUsedAt    DateTime?
  createdAt     DateTime     @default(now())
  revokedAt     DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
  @@index([projectId, provider])
}

// Borrador de HU generado por un LLM partiendo de:
//   - rawInput (necesidad del usuario)
//   - selectedPaths (archivos del repo incluidos como contexto)
//   - citedMemoryIds (memorias del cerebro inyectadas como contexto)
// Las secciones del output se llenan incrementalmente durante el stream.

model StoryDraft {
  id              String           @id @default(cuid())
  projectId       String
  authorId        String
  parentDraftId   String?          // para regeneraciones
  taskId          String?          @unique // si se publicó como Task

  // Input
  rawInput        String           @db.Text
  provider        LlmProvider
  model           String
  selectedPaths   String[]
  citedMemoryIds  String[]

  // Output (sección por sección)
  summary             String?  @db.Text
  acceptanceCriteria  String?  @db.Text
  technicalContext    String?  @db.Text
  subtaskBreakdown    Json?    // [{ title, description, priority }]
  filesToTouch        Json?    // [{ path, reason }]
  risks               String?  @db.Text

  // Telemetría
  inputTokens         Int      @default(0)
  outputTokens        Int      @default(0)
  estimatedCostUsd    Decimal  @default(0) @db.Decimal(10, 6)
  durationMs          Int      @default(0)

  // Lifecycle
  status              StoryDraftStatus @default(GENERATING)
  errorMessage        String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
  parent  StoryDraft?   @relation("DraftLineage", fields: [parentDraftId], references: [id])
  forks   StoryDraft[]  @relation("DraftLineage")
  task    Task?         @relation("PublishedFrom", fields: [taskId], references: [id])

  @@index([projectId, createdAt])
  @@index([authorId, createdAt])
}

// Ámbito de un resumen de contexto generado por el modelo self-hosted (Ollama
// en fusion-infra). PROJECT = visión global del proyecto; TASK = contexto de
// una HU/tarea concreta (refId = Task.id).
enum ContextScope {
  PROJECT
  TASK
}

// Resumen narrativo cacheado del grafo de contexto. Se regenera bajo demanda o
// cuando queda obsoleto (p. ej. tras completarse tareas). `refId` = projectId
// para scope PROJECT, o el id de la Task para scope TASK.
model ContextSummary {
  id        String       @id @default(cuid())
  projectId String
  scope     ContextScope
  refId     String
  body      String       @db.Text
  model     String
  // Señal de frescura: nº de nodos/aristas en el momento de generar, para saber
  // si el grafo cambió lo suficiente como para regenerar.
  signature String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([scope, refId])
  @@index([projectId, scope])
}

// ============================================================
// Skills package — a shared, org-wide registry of best-practice
// commands/guidelines that Fusion Code (Qwen) syncs into ~/.qwen.
// Global (not project-scoped); devs contribute new ones for review.
// ============================================================

enum SkillCategory {
  TESTING
  QUALITY
  WORKFLOW
  ARCHITECTURE
  GIT
  OTHER
}

enum SkillKind {
  COMMAND // a slash command like /cerrar-hu
  GUIDELINE // an always-applied best practice
}

enum SkillStatus {
  PENDING // contributed by a dev, awaiting review
  APPROVED // available to sync
  DEPRECATED
}

model Skill {
  id          String        @id @default(cuid())
  slug        String        @unique // kebab-case, used as the command name
  name        String
  description String
  category    SkillCategory @default(OTHER)
  kind        SkillKind     @default(COMMAND)
  body        String        @db.Text // markdown = the skill/command Qwen executes
  official    Boolean       @default(false) // curated team standard
  status      SkillStatus   @default(PENDING)
  version     Int           @default(1)
  tags        String[]
  authorId    String? // contributor (plain id; no back-relation)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, category])
  @@index([official])
}
