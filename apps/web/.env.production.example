# ============================================================
# Variables de entorno para producción (Coolify u otro orquestador)
# ============================================================
# Copia este archivo a .env.production y rellena los valores REALES.
# Ese archivo NUNCA debe commitearse — está en .gitignore (.env*).
# En Coolify, no hace falta el archivo; las variables se setean
# desde el dashboard como "Application Environment Variables".
# ------------------------------------------------------------

# ---- Database (gestionada por Coolify como service "postgres") ----
# Coolify inyecta esto automáticamente referenciando el service.
# Formato: postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
DATABASE_URL=postgresql://admin:GENERAR_CON_openssl_rand_hex_24@db:5432/admin_data?schema=public&sslmode=prefer

# ---- Auth.js v5 ----
# Generar: openssl rand -base64 32
AUTH_SECRET=GENERAR_CON_openssl_rand_base64_32
# URL pública del deploy (con protocolo y puerto). Auth.js valida origin.
AUTH_URL=https://admin.47-184-25-55.sslip.io:8443
AUTH_TRUST_HOST=true

# ---- TOTP / 2FA + sealing de LlmCredential (server-side) ----
# Generar: openssl rand -base64 32
# Si la pierdes, los secretos sellados (LLM API keys) se vuelven irrecuperables.
AUTH_TOTP_KEY=GENERAR_CON_openssl_rand_base64_32

# ---- LLM providers (los necesarios para tu uso) ----
# Anthropic: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXX
# Opcional: defaults razonables si no se setean
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MODEL_BALANCED=claude-sonnet-4-6
AI_MODEL_DEEP=claude-opus-4-7

# ---- Runtime ----
NODE_ENV=production
LOG_LEVEL=info
