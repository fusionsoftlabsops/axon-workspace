# ============================================================
# Variables de entorno para producción (Coolify u otro orquestador)
# ============================================================
# Copia este archivo a .env.production y rellena los valores REALES.
# Ese archivo NUNCA debe commitearse — está en .gitignore (.env*).
# En Coolify, no hace falta el archivo; las variables se setean
# desde el dashboard como "Application Environment Variables".
# ------------------------------------------------------------

# ---- Database (gestionada por Coolify como service "postgres") ----
# Coolify inyecta esto automáticamente referenciando el service.
# Formato: postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
DATABASE_URL=postgresql://admin:GENERAR_CON_openssl_rand_hex_24@db:5432/admin_data?schema=public&sslmode=prefer

# ---- Auth.js v5 ----
# Generar: openssl rand -base64 32
AUTH_SECRET=GENERAR_CON_openssl_rand_base64_32
# URL pública del deploy (con protocolo y puerto). Auth.js valida origin.
AUTH_URL=https://admin.47-184-25-55.sslip.io:8443
AUTH_TRUST_HOST=true

# ---- TOTP / 2FA (server-side) ----
# Generar: openssl rand -base64 32
# Respaldar junto con AUTH_SECRET y AUTH_LLM_KEY: sin ellas, sesiones/TOTP/LLM
# keys son irrecuperables.
AUTH_TOTP_KEY=GENERAR_CON_openssl_rand_base64_32

# ---- Sealing de LlmCredential (server-side, clave DEDICADA) ----
# Generar: openssl rand -base64 32
# Separada de AUTH_TOTP_KEY para acotar el blast-radius. Tras setearla en un
# deploy con credenciales LLM existentes, migrarlas:
#   node --env-file=.env scripts/rotate-llm-key.mjs --apply
AUTH_LLM_KEY=GENERAR_CON_openssl_rand_base64_32

# ---- Repos (lectura sandboxed; RepoReader / generador de HU) ----
# Confina project.repoPath a esta raíz. La carpeta debe existir en el server.
REPOS_ROOT=/srv/repos

# ---- LLM providers (los necesarios para tu uso) ----
# Anthropic: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXX
# Opcional: defaults razonables si no se setean
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MODEL_BALANCED=claude-sonnet-4-6
AI_MODEL_DEEP=claude-opus-4-8

# ---- SMTP (opcional) — emails de invitación ----
# Hostinger: host smtp.hostinger.com, port 465 (SSL) o 587 (STARTTLS).
# Resend: host smtp.resend.com, user "resend", pass = la API key.
# Si se deja vacío, la invitación solo genera el enlace copiable.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=operaciones@fusionsoftlabscolombia.com
SMTP_PASS=LA_CONTRASEÑA_DEL_BUZON
SMTP_FROM=operaciones@fusionsoftlabscolombia.com

# ---- Almacenamiento de archivos (MinIO / S3) ----
# Instancia MinIO dedicada de Axon. Endpoint interno por la red `fusion`
# (no público). Si se dejan vacíos, la pestaña Archivos responde 503.
S3_ENDPOINT=http://axon-storage:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=                 # MINIO_ROOT_USER de la instancia
S3_SECRET_ACCESS_KEY=             # 🔒 MINIO_ROOT_PASSWORD (mostrado una vez al crear)
S3_BUCKET=axon
S3_FORCE_PATH_STYLE=true

# ---- Runtime ----
NODE_ENV=production
LOG_LEVEL=info
