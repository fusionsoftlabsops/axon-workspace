{
  "name": "@admin/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Worker de la plataforma agéntica: se suscribe a los eventos de dominio de HUs (Redis) y los enruta a los handlers de rol (SM/Dev/QA).",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "2.1.9"
  }
}
