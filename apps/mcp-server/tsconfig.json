{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true,
    "noEmit": false,
    "target": "ES2022",
    "lib": ["ES2023"],
    "baseUrl": ".",
    "paths": {
      "@admin/shared": ["../../packages/shared/src"],
      "@admin/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
