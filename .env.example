# ===========================
# admin_data_project - example env
# ===========================
# Copy to .env and fill in real values. Never commit .env.

# --- Database ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=admin_data
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:changeme_local_only@localhost:5432/admin_data?schema=public

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_random_base64_32_bytes
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Server-side key for encrypting TOTP secrets at rest. Generate: openssl rand -base64 32
# IMPORTANTE: respaldá AUTH_SECRET, AUTH_TOTP_KEY y AUTH_LLM_KEY tan críticamente
# como la DB — sin ellas, sesiones/TOTP/LLM keys son irrecuperables.
AUTH_TOTP_KEY=replace_with_random_base64url_32_bytes
# Clave DEDICADA para sellar las API keys de LLM (separada de AUTH_TOTP_KEY para
# acotar el blast-radius). Generar: openssl rand -base64 32
# Tras setearla en un deploy existente, migrá las credenciales con:
#   node --env-file=.env scripts/rotate-llm-key.mjs --apply
AUTH_LLM_KEY=replace_with_random_base64url_32_bytes

# --- Repos (lectura sandboxed para el generador de HU / RepoReader) ---
# Si se setea, TODO project.repoPath debe vivir dentro de esta raíz. Sin ella,
# un OWNER/ADMIN podría apuntar repoPath a cualquier ruta del server.
REPOS_ROOT=/srv/repos

# --- Anthropic (IA + MCP) ---
ANTHROPIC_API_KEY=sk-ant-...

# Model routing defaults
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MODEL_BALANCED=claude-sonnet-4-6
AI_MODEL_DEEP=claude-opus-4-8

# --- MCP server (cliente) ---
# El MCP server local consume el API de la web app con este token.
# Generar desde /settings/tokens despues del primer login.
ADMIN_API_BASE_URL=http://localhost:3000/api/v1
ADMIN_API_TOKEN=

# --- SMTP (opcional) — envío de emails de invitación ---
# Si se deja vacío, las invitaciones solo generan el enlace copiable (sin email).
# Sirve cualquier proveedor SMTP (Hostinger, Resend via smtp.resend.com, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=operaciones@fusionsoftlabscolombia.com

# --- App ---
NODE_ENV=development
LOG_LEVEL=info
